# ─── 키움증권 API ───────────────────────────────
KIWOOM_APP_KEY=YOUR_KIWOOM_APP_KEY
KIWOOM_APP_SECRET=YOUR_KIWOOM_APP_SECRET
KIWOOM_BASE_URL=https://api.kiwoom.com
KIWOOM_WS_URL=wss://api.kiwoom.com:10000
# 모의투자 시
# KIWOOM_BASE_URL=https://mockapi.kiwoom.com
# KIWOOM_WS_URL=wss://mockapi.kiwoom.com:10000
KIWOOM_MODE=real

# ─── Claude AI ──────────────────────────────────
CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── Telegram ───────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# 알림을 받을 채팅 ID (콤마 구분 복수 가능)
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_ALLOWED_CHAT_IDS=YOUR_TELEGRAM_CHAT_ID
# true 로 설정 시 실제 전송 없이 로그만 출력 (테스트용)
TELEGRAM_DRY_RUN=false

# ─── Redis ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ─── PostgreSQL ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=SMA
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# ─── 암호화 키 ───────────────────────────────────
ENCRYPT_SECRET_KEY=YOUR_32_CHAR_SECRET_KEY

# ─── ai-engine 설정 ──────────────────────────────
LOG_LEVEL=INFO
ENABLE_STRATEGY_SCANNER=false
STRATEGY_SCAN_INTERVAL_SEC=60
MAX_CONCURRENT_STRATEGIES=3
AI_HEALTH_PORT=8082

# ─── api-orchestrator 설정 ───────────────────────
JPA_DDL_AUTO=update
SIGNAL_DUPLICATE_TTL=3600
