# -----------------------------------------------------------------------------
# Kiwoom API
# -----------------------------------------------------------------------------
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_BASE_URL=https://api.kiwoom.com
KIWOOM_WS_URL=wss://api.kiwoom.com:10000
KIWOOM_MODE=real
KIWOOM_API_INTERVAL=0.25
JAVA_WS_ENABLED=false
BYPASS_MARKET_HOURS=false

# -----------------------------------------------------------------------------
# Claude / Anthropic
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_ANALYST_TIMEOUT_SEC=30
CLAUDE_ANALYST_MINUTE_SCOPE=5
MAX_CLAUDE_CALLS_PER_DAY=100
MAX_NEWS_CLAUDE_CALLS=5

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_PRIMARY_CHAT_ID=
TELEGRAM_DRY_RUN=false
POLL_INTERVAL_MS=2000
MIN_AI_SCORE=65

# -----------------------------------------------------------------------------
# Internal service URLs
# -----------------------------------------------------------------------------
API_BASE_URL=http://api-orchestrator:8080
API_ORCHESTRATOR_BASE_URL=http://api-orchestrator:8080
AI_ENGINE_URL=http://ai-engine:8082

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=SMA
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
PG_WRITER_ENABLED=true

# -----------------------------------------------------------------------------
# Security / encryption
# -----------------------------------------------------------------------------
ENCRYPT_SECRET_KEY=

# -----------------------------------------------------------------------------
# Runtime / logging
# -----------------------------------------------------------------------------
TZ=Asia/Seoul
LOG_LEVEL=INFO
SERVICE_NAME=telegram-bot
LOG_FILE=../../logs/telegram-bot.log

# -----------------------------------------------------------------------------
# Health ports
# NOTE: HEALTH_PORT is currently used by websocket-listener.
# telegram-bot currently falls back to HEALTH_PORT too; this should be split to
# TELEGRAM_HEALTH_PORT in the OCI deployment work.
# -----------------------------------------------------------------------------
HEALTH_PORT=8081
AI_HEALTH_PORT=8082
TELEGRAM_HEALTH_PORT=3001

# -----------------------------------------------------------------------------
# api-orchestrator trading controls
# -----------------------------------------------------------------------------
JPA_DDL_AUTO=validate
SIGNAL_DUPLICATE_TTL=7200
MAX_DAILY_SIGNALS=30
SECTOR_OVERHEAT_THRESHOLD=3
STOCK_COOLDOWN_MINUTES=30
SWING_STRATEGIES=S3_INST_FRGN,S5_PROG_FRGN,S7_ICHIMOKU_BREAKOUT,S8_GOLDEN_CROSS,S9_PULLBACK_SWING,S10_NEW_HIGH,S11_FRGN_CONT,S12_CLOSING,S13_BOX_BREAKOUT,S14_OVERSOLD_BOUNCE,S15_MOMENTUM_ALIGN
NEWS_TRADING_CONTROL=true
ENABLE_STRATEGY_SESSION_FILTER=true
STRATEGY_SESSION_DRY_RUN=false
STRATEGY_SESSION_FAIL_OPEN=true
SESSION_ENTER_GUARD_ENABLED=true
NEWS_SECTOR_FILTER=true

# -----------------------------------------------------------------------------
# ai-engine worker toggles
# -----------------------------------------------------------------------------
ENABLE_STRATEGY_SCANNER=true
ENABLE_MONITOR=true
ENABLE_STATUS_REPORT=true
ENABLE_POSITION_MONITOR=true
ENABLE_POSITION_REASSESSMENT=true
ENABLE_OVERNIGHT_WORKER=true
ENABLE_VI_WATCH_WORKER=true
ENABLE_CANDIDATE_BUILDER=true
REVERSAL_CLAUDE_ENABLED=true

# -----------------------------------------------------------------------------
# ai-engine intervals / timeouts
# -----------------------------------------------------------------------------
STRATEGY_SCAN_INTERVAL_SEC=60
MAX_CONCURRENT_STRATEGIES=3
STRATEGY_TIMEOUT_SEC=300
STRATEGY_TIMEOUT_S3_SEC=300
STRATEGY_TIMEOUT_S11_SEC=300
SLOW_STRATEGY_WARN_SEC=30
CANDIDATE_BUILD_INTERVAL_SEC=600
POLL_INTERVAL_SEC=2.0
STATUS_DECISION_TTL_SEC=600
STATUS_REPORT_SLOTS=08:30,12:00,15:40
POSITION_MONITOR_INTERVAL_SEC=30
POSITION_REASSESS_INTERVAL_SEC=300
POSITION_REASSESS_CACHE_TTL_SEC=900
POSITION_REASSESS_MIN_SCOPE=5
REVERSAL_CLAUDE_COOLDOWN_SEC=120
OVERNIGHT_POLL_SEC=2.0
MONITOR_INTERVAL_SEC=60

# -----------------------------------------------------------------------------
# Queue / monitor thresholds
# -----------------------------------------------------------------------------
MONITOR_QUEUE_DEPTH_WARN=50
MONITOR_ERROR_QUEUE_WARN=5
MONITOR_MEMORY_WARN_PCT=80.0
SELL_RECOMMENDATION_QUEUE=ai_scored_queue
SELL_RECOMMENDATION_DEDUP_TTL_SEC=43200

# -----------------------------------------------------------------------------
# News
# -----------------------------------------------------------------------------
NEWS_ENABLED=true
NEWS_INTERVAL_MIN=30
NEWS_MAX_ITEMS=30
NEWS_MIN_RELEVANCE=2
NEWS_PER_SOURCE_LIMIT=14

# -----------------------------------------------------------------------------
# Scoring / risk policy
# -----------------------------------------------------------------------------
AI_SCORE_THRESHOLD=60.0
RR_HARD_CANCEL_THRESHOLD=0.8
RR_CAUTION_THRESHOLD=1.2
HOLD_TO_ENTER_MIN_AI_SCORE=80.0
MIN_RR_RATIO=1.3
TP_SL_STRATEGY_VERSION=ta_v2_2026_04
SLIP_FEE_KOSPI=0.0035
SLIP_FEE_KOSDAQ=0.0045

# -----------------------------------------------------------------------------
# Indicator caches
# -----------------------------------------------------------------------------
MA_CACHE_TTL_SEC=3600
RSI_MIN_CACHE_TTL_SEC=300

# -----------------------------------------------------------------------------
# Strategy-specific parameters
# -----------------------------------------------------------------------------
S3_KA10055_MAX_PAGES=3
S3_CONTINUOUS_DAYS=3
S10_NEW_HIGH_TERM=250
S12_MIN_FLU_RT=4.0
S12_MIN_CNTR_STR=110.0
S13_MIN_CNTR_STR=120.0
SWING_SIGNAL_DEDUP_SEC=7200
INTRADAY_SIGNAL_DEDUP_SEC=1800
STATUS_SIGNAL_TTL_SEC=600
